{
  "panels": [
    {
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(spendsense_requests_total[1m])",
          "legendFormat": "{{endpoint}} {{status}}"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "Not Loaded"
                },
                "1": {
                  "color": "green",
                  "text": "Model Loaded"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(spendsense_model_loaded * up{job=\"spendsense_backend\"}) or vector(0)",
          "legendFormat": "Model Status"
        }
      ],
      "title": "Model Loaded",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "spendsense_predictions_by_category_total",
          "legendFormat": "{{category}}"
        }
      ],
      "title": "Predictions by Category",
      "type": "piechart"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(spendsense_requests_total)",
          "legendFormat": "Total"
        }
      ],
      "title": "Total Requests",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p99"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "p95"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "p50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "id": 13,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(spendsense_request_latency_seconds_bucket{endpoint=\"/predict\"}[1m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(spendsense_request_latency_seconds_bucket{endpoint=\"/predict\"}[1m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(spendsense_request_latency_seconds_bucket{endpoint=\"/predict\"}[1m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "Latency Percentiles \u2014 P50 / P95 / P99 (seconds)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 28
      },
      "id": 17,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name",
        "thresholds": {
          "steps": [
            {
              "color": "green",
              "value": 0
            },
            {
              "color": "red",
              "value": 1
            }
          ]
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "spendsense_pipeline_drift_detected",
          "legendFormat": "Drift Detected"
        }
      ],
      "title": "Airflow Drift Flag",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 28
      },
      "id": 23,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "pie",
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (alertname) (count_over_time(ALERTS{alertstate=\"firing\"}[$__range]))",
          "instant": true,
          "legendFormat": "{{alertname}}"
        }
      ],
      "title": "Alerts Fired by Name",
      "type": "piechart"
    },
    {
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "id": 24,
      "options": {
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Fired At"
          }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ALERTS{alertstate=\"firing\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "title": "Recent Email Alerts",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "Time",
                "alertname",
                "severity"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Time": "Fired At",
              "alertname": "Alert Name",
              "severity": "Severity"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "SpendSense \u2014 MLOps Dashboard",
  "uid": "spendsense-main"
}
{
  "title": "SpendSense — MLOps Dashboard",
  "uid": "spendsense-main",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(spendsense_requests_total[1m])",
          "legendFormat": "{{endpoint}} {{status}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Model Loaded",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Model Loaded", "color": "green" },
                "0": { "text": "Not Loaded",   "color": "red"   }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(spendsense_model_loaded * up{job=\"spendsense_backend\"}) or vector(0)",
          "legendFormat": "Model Status",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "Predictions by Category",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 8, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "spendsense_predictions_by_category_total",
          "legendFormat": "{{category}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(spendsense_requests_total)",
          "legendFormat": "Total",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 13,
      "title": "Latency Percentiles — P50 / P95 / P99 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(spendsense_request_latency_seconds_bucket{endpoint=\"/predict\"}[1m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(spendsense_request_latency_seconds_bucket{endpoint=\"/predict\"}[1m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, rate(spendsense_request_latency_seconds_bucket{endpoint=\"/predict\"}[1m]))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 17,
      "title": "Airflow Drift Flag",
      "type": "stat",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red",   "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "expr": "spendsense_pipeline_drift_detected",
          "legendFormat": "Drift Detected",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 23,
      "title": "Alerts Fired by Name",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 8 },
      "options": {
        "pieType": "pie",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "expr": "sum by (alertname) (count_over_time(ALERTS{alertstate=\"firing\"}[$__range]))",
          "legendFormat": "{{alertname}}",
          "datasource": "Prometheus",
          "instant": true
        }
      ]
    },
    {
      "id": 24,
      "title": "Recent Email Alerts",
      "type": "table",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 8 },
      "options": {
        "sortBy": [{ "desc": true, "displayName": "Fired At" }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } }
      },
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "names": ["Time", "alertname", "severity"] }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Time": "Fired At",
              "alertname": "Alert Name",
              "severity": "Severity"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "",
          "datasource": "Prometheus",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ]
}
